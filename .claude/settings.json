{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(npm install*)",
      "Bash(npx *)",
      "Bash(node --test*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push origin *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git restore *)",
      "Bash(supabase start)",
      "Bash(supabase stop)",
      "Bash(supabase status*)",
      "Bash(supabase migration *)",
      "Bash(supabase db reset)",
      "Read(src/**)",
      "Read(supabase/**)",
      "Read(tests/**)",
      "Read(public/**)",
      "Read(package.json)",
      "Read(tsconfig.json)",
      "Read(next.config.mjs)",
      "Read(.claude/**)",
      "Read(*.md)",
      "Write(src/**)",
      "Write(supabase/**)",
      "Write(tests/**)",
      "Write(public/**)",
      "Write(*.md)",
      "Write(.claude/**)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(aws *)",
      "Bash(curl * | bash)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(supabase db push*)",
      "Bash(supabase link*)",
      "Read(.env)",
      "Read(.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(node_modules/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-secrets.sh",
            "if": "Bash(git commit *)"
          }
        ]
      }
    ]
  }
}
