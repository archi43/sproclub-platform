# Supabase (region EU). Never commit real values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by trusted server code (tenant resolution, admin tasks).
SUPABASE_SERVICE_ROLE_KEY=

# Base domain for subdomain-based tenant resolution, e.g. "sproclub.app".
# A tenant is reached at <org-slug>.sproclub.app or via its custom domain.
APP_BASE_DOMAIN=localhost:3000

# Default organization on the platform root (no sub-domain).
# PLATFORM_DEFAULT_ORG_SLUG: single-tenant deployment (pilot/staging), honored in
#   every environment. Leave UNSET for a true multi-tenant deployment.
# DEV_DEFAULT_ORG_SLUG: local-dev convenience only, ignored in production.
PLATFORM_DEFAULT_ORG_SLUG=
DEV_DEFAULT_ORG_SLUG=

# Cal.com (booking). Pilot: single org via env. In prod the token is resolved
# per organization from the secret manager (connector_configs.secret_ref).
# The two event type ids back the two calendars (coaching / defense).
# EU region (RGPD) uses the Cal.eu instance → base https://api.cal.eu/v2
# (US cloud would be https://api.cal.com/v2).
CALCOM_API_BASE=https://api.cal.eu/v2
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_COACHING=
CALCOM_EVENT_TYPE_DEFENSE=

# Availability mirror (Cal.com slots -> availabilities table).
# CALCOM_HOST_PROFILE_ID: the profile that hosts mirrored slots (host_id).
# CRON_SECRET: shared secret to authorize POST /api/admin/mirror-availabilities.
CALCOM_HOST_PROFILE_ID=
CRON_SECRET=

# Airtable source (INC-1, sync Airtable -> Postgres). INC-14: pour activer le
# write-back (CR -> "Comptes rendus -header"), le token doit aussi porter
# data.records:write et AIRTABLE_WRITEBACK_ENABLED=true. CREATE uniquement,
# jamais de modification/suppression d'enregistrements existants.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
# Optional override; defaults to the SproCLUB "Commandes Formation" table.
AIRTABLE_COMMANDES_TABLE_ID=
AIRTABLE_WRITEBACK_ENABLED=
# Optional override; defaults to the SproCLUB "Comptes rendus -header" table.
AIRTABLE_CR_TABLE_ID=

# Fillout (INC-14, évaluations -> coaching_reports, source='fillout').
# FILLOUT_FORM_IDS: ids de formulaires à ingérer, séparés par des virgules.
FILLOUT_API_KEY=
FILLOUT_FORM_IDS=
